# =============================================================================
# VIDEO UPLOAD BOT — Пример конфигурации окружения
# =============================================================================
# Скопируйте этот файл в .env и заполните все значения:
#   cp .env.example .env
#
# Обязательные переменные помечены [REQUIRED]
# Опциональные переменные помечены [OPTIONAL]
# =============================================================================


# =============================================================================
# TELEGRAM
# =============================================================================

# [REQUIRED] Токен Telegram-бота
# Где взять: https://t.me/BotFather → /newbot → скопировать токен
# Формат: числа:буквы-цифры (например: 1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# [REQUIRED] Telegram ID администратора (единственный пользователь бота)
# Где взять: написать @userinfobot или @getmyid_bot в Telegram
# Формат: целое число (например: 123456789)
TELEGRAM_ADMIN_ID=your_telegram_admin_id_here


# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# [REQUIRED] URL подключения к PostgreSQL
# Формат: postgresql://пользователь:пароль@хост:порт/база_данных
# Пример локально: postgresql://postgres:password@localhost:5432/video_bot
# Пример на сервере: postgresql://video_bot:strongpassword@localhost:5432/video_bot
DATABASE_URL=postgresql://user:password@localhost:5432/video_upload_bot


# =============================================================================
# REDIS
# =============================================================================

# [REQUIRED] URL подключения к Redis (используется BullMQ для очередей)
# Формат: redis://[:пароль@]хост:порт[/номер_базы]
# Пример без пароля: redis://localhost:6379
# Пример с паролем: redis://:strongpassword@localhost:6379
REDIS_URL=redis://localhost:6379


# =============================================================================
# YOUTUBE API
# =============================================================================
# Консоль разработчика: https://console.cloud.google.com/
# Инструкция:
#   1. Создать проект → APIs & Services → Enable APIs → YouTube Data API v3
#   2. Credentials → Create Credentials → OAuth 2.0 Client ID
#   3. Application type: Web application
#   4. Authorized redirect URIs: http://{SERVER_IP}:{PORT}/auth/youtube/callback

# [REQUIRED] Client ID из Google OAuth 2.0
# Формат: числа-буквы.apps.googleusercontent.com
YOUTUBE_CLIENT_ID=your_youtube_client_id_here

# [REQUIRED] Client Secret из Google OAuth 2.0
# Формат: GOCSPX-буквы_и_цифры
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here


# =============================================================================
# INSTAGRAM API (Meta Graph API)
# =============================================================================
# Консоль разработчика: https://developers.facebook.com/
# Инструкция:
#   1. My Apps → Create App → Business → добавить Instagram Graph API
#   2. App Settings → Basic → скопировать App ID и App Secret
#   3. Instagram → Settings → добавить redirect URI: http://{SERVER_IP}:{PORT}/auth/instagram/callback
#   4. Запросить разрешения: instagram_basic, instagram_content_publish, pages_read_engagement

# [REQUIRED] App ID из Meta for Developers
# Формат: числовая строка (например: 1234567890123456)
INSTAGRAM_CLIENT_ID=your_instagram_app_id_here

# [REQUIRED] App Secret из Meta for Developers
# Формат: hex-строка 32 символа
INSTAGRAM_CLIENT_SECRET=your_instagram_app_secret_here


# =============================================================================
# TIKTOK API (TikTok for Business)
# =============================================================================
# Консоль разработчика: https://developers.tiktok.com/
# Инструкция:
#   1. Manage Apps → Create App → выбрать категорию
#   2. Products → Login Kit → добавить redirect URI: http://{SERVER_IP}:{PORT}/auth/tiktok/callback
#   3. Products → Content Posting API → подать заявку на доступ
#   4. Скопировать Client Key и Client Secret из App Detail

# [REQUIRED] Client Key из TikTok for Developers
# Формат: буквенно-цифровая строка
TIKTOK_CLIENT_ID=your_tiktok_client_key_here

# [REQUIRED] Client Secret из TikTok for Developers
# Формат: буквенно-цифровая строка
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here


# =============================================================================
# ШИФРОВАНИЕ ТОКЕНОВ
# =============================================================================

# [REQUIRED] Ключ шифрования OAuth-токенов (AES-256-GCM)
# Формат: hex-строка ровно 64 символа (= 32 байта)
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ВАЖНО: храните в тайне, не коммитьте в git, не меняйте после первого запуска
#         (смена ключа сделает все сохранённые токены нечитаемыми)
TOKEN_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here


# =============================================================================
# СЕРВЕР
# =============================================================================

# [REQUIRED] IP-адрес сервера для формирования OAuth callback URL
# Формат: IPv4-адрес или домен (без http://)
# Пример: 89.124.70.156 или myserver.example.com
# Используется в URL: http://{SERVER_IP}:{PORT}/auth/{platform}/callback
SERVER_IP=your_server_ip_here

# [OPTIONAL] Полный базовый URL сервера для OAuth callback (приоритет над SERVER_IP+PORT)
# Используйте если у вас есть домен с HTTPS через nginx proxy
# Формат: https://ваш-домен.com (без слеша в конце)
# Пример: https://vidrimers.site
# Если задан — callback URL будет: {SERVER_URL}/auth/{platform}/callback
SERVER_URL=

# [REQUIRED] Порт HTTP-сервера (Fastify)
# Формат: целое число от 1024 до 65535
# Рекомендуется: 3000 (или любой свободный порт)
PORT=3000

# [OPTIONAL] Окружение запуска
# Значения: development | production
# По умолчанию: development
NODE_ENV=development


# =============================================================================
# ЗАГРУЗКА ВИДЕО
# =============================================================================

# [OPTIONAL] Директория для временного хранения видеофайлов
# Формат: относительный или абсолютный путь
# По умолчанию: ./temp
# Пример на сервере: /home/meowgang-bot/uploads
VIDEO_UPLOAD_DIR=./temp/videos

# [OPTIONAL] Максимальный размер видеофайла в байтах
# Формат: целое число
# Примеры:
#   524288000  = 500 MB
#   1073741824 = 1 GB
#   2147483648 = 2 GB (по умолчанию)
MAX_FILE_SIZE_BYTES=2147483648
